{
  "name": "camp-404",
  "private": true,
  "version": "0.0.0",
  "description": "Camp 404 — cross-platform camp management app for the Afrikaburn theme camp",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "design:extract-boards": "node scripts/pencil/extract-boards.mjs design/app.pen design/.spec-extract"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "overrides": {
      "better-auth": "~1.4.18"
    }
  }
}
