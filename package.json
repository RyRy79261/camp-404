{
  "name": "camp-404",
  "private": true,
  "version": "0.0.0",
  "description": "Camp 404 — cross-platform camp management app for the Afrikaburn theme camp",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "design:extract-boards": "node scripts/pencil/extract-boards.mjs design/app.pen design/.spec-extract"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "overrides": {
      "better-auth": "~1.4.18",
      "esbuild": ">=0.28.1",
      "form-data@<2.5.6": "^2.5.6",
      "vite@>=8.0.0 <=8.0.15": "^8.0.16",
      "hono@<4.12.25": "^4.12.25",
      "undici@<6.27.0": "^6.27.0",
      "undici@>=7.0.0 <7.28.0": "^7.28.0",
      "protobufjs@<7.6.3": "^7.6.3",
      "tar@<7.5.16": "^7.5.16",
      "@babel/core@<7.29.6": "^7.29.6",
      "postcss@<8.5.10": "^8.5.10"
    }
  }
}
