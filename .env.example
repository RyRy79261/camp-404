# Camp 404 — example environment variables.
# Copy to .env.local in apps/web (and other apps that need it) and fill in.

# --- Database (Neon Postgres) ---
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# --- Auth.js v5 ---
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Magic-link email (primary provider)
AUTH_EMAIL_SERVER=smtp://user:pass@smtp.example.com:587
AUTH_EMAIL_FROM=no-reply@camp-404.com

# Google OAuth (convenience provider)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# CI / Agent service token (long-lived, scoped to test- prefixed data)
AUTH_AGENT_TOKEN=

# --- File storage (Vercel Blob) ---
BLOB_READ_WRITE_TOKEN=

# --- AI providers ---
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# --- Push (Firebase Admin SDK) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Payment (Zapper) ---
ZAPPER_MERCHANT_API_KEY=
ZAPPER_WEBHOOK_SECRET=

# --- Cron + crypto ---
CRON_SECRET=
PGCRYPTO_KEY=
