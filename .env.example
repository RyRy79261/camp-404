# Camp 404 — example environment variables.
# Copy to .env.local in apps/web (and other apps that need it) and fill in.

# --- Database (Neon Postgres) ---
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# --- Neon Auth (Better Auth) ---
# Get the base URL from Neon Console → your project → Auth → Configuration.
# Generate a cookie secret (32+ chars) with: openssl rand -base64 32
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=

# --- File storage (Vercel Blob) ---
BLOB_READ_WRITE_TOKEN=

# --- AI providers ---
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# --- Push (Firebase Admin SDK) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Telegram bot ---
# Bot token from @BotFather. Bot must be made an admin of the camp's
# main group AND announcement channel for createChatInviteLink + post.
TELEGRAM_BOT_TOKEN=
# Random secret passed to setWebhook + checked on every incoming update.
# Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# --- Cron + crypto ---
# Bearer secret for /api/cron/* endpoints.
CRON_SECRET=
# pgcrypto symmetric key for passport / SA-ID / EFT columns. Rotate annually.
PGCRYPTO_KEY=

# --- Signup gating ---
# Comma-separated list of currently-valid invite codes. Bootstrap fallback
# (unlimited uses, no DB row required); leave empty in production and
# issue DB-backed codes via `camp404 mint-invite` instead. The founder's
# first code is minted via `camp404 bootstrap-founder --email …`.
INVITE_CODES=
# Comma-separated list of email addresses that bypass the invite-code check.
# These are the "god accounts" — Camp Lead etc.
GOD_EMAILS=

# --- In-app feedback (GitHub Issues) ---
# Fine-grained PAT with "Issues: Read and write" on RyRy79261/camp-404.
# Optional / not boot-required — the "shake to report" modal degrades to a
# "not set up yet" message when this is unset.
GITHUB_FEEDBACK_TOKEN=
# Optional; target repo for filed issues. Defaults to RyRy79261/camp-404.
GITHUB_FEEDBACK_REPO=
