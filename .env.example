# Camp 404 — example environment variables.
# Copy to .env.local in apps/web (and other apps that need it) and fill in.

# --- Database (Neon Postgres) ---
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# --- Neon Auth (Better Auth) ---
# Get the base URL from Neon Console → your project → Auth → Configuration.
# Generate a cookie secret (32+ chars) with: openssl rand -base64 32
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=

# --- File storage (Vercel Blob) ---
BLOB_READ_WRITE_TOKEN=

# --- AI providers ---
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# --- Push (Firebase Admin SDK) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Cron + crypto ---
# Bearer secret for /api/cron/* endpoints.
CRON_SECRET=
# pgcrypto symmetric key for passport / SA-ID / EFT columns. Rotate annually.
PGCRYPTO_KEY=

# --- Signup gating ---
# Comma-separated list of currently-valid invite codes. Empty = no codes
# are valid (so only god accounts can sign up). Codes are case-sensitive.
INVITE_CODES=
# Comma-separated list of email addresses that bypass the invite-code check.
# These are the "god accounts" — Camp Lead etc.
GOD_EMAILS=
