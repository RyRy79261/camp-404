# Camp 404 — example environment variables.
# Copy to .env.local in apps/web (and other apps that need it) and fill in.

# --- Database (Neon Postgres) ---
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# --- Neon Auth (Stack) ---
# Get these from Neon Console → your project → Auth → Configuration.
NEXT_PUBLIC_STACK_PROJECT_ID=
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=
STACK_SECRET_SERVER_KEY=

# --- File storage (Vercel Blob) ---
BLOB_READ_WRITE_TOKEN=

# --- AI providers ---
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# --- Push (Firebase Admin SDK) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Cron + crypto ---
# Bearer secret for /api/cron/* endpoints.
CRON_SECRET=
# pgcrypto symmetric key for passport / SA-ID / EFT columns. Rotate annually.
PGCRYPTO_KEY=
